# AlphaCore — Environment Variables Template
# Copy this file to .env and fill in your values. Never commit .env to git.

# Binance API key — get from https://testnet.binance.vision/
BINANCE_API_KEY=your_testnet_api_key_here
# Binance API secret — get from https://testnet.binance.vision/
BINANCE_API_SECRET=your_testnet_api_secret_here
# Set to true for Binance Testnet, false for real-money live trading (default: true)
# ⚠ WARNING: Setting this to false requires I_UNDERSTAND_THIS_IS_REAL_MONEY=true below
BINANCE_TESTNET=true
# Explicit acknowledgment for real-money trading — must be set to "true" when BINANCE_TESTNET=false
I_UNDERSTAND_THIS_IS_REAL_MONEY=false

# Real Binance API credentials (read-only) — for real-money account visibility
# These keys MUST be created with only read-only permissions on Binance.
# ⚠ Never give these keys trading or withdrawal permissions.
BINANCE_REAL_API_KEY=your_real_binance_api_key_here
BINANCE_REAL_API_SECRET=your_real_binance_api_secret_here
# Set to "true" to enable the real account-sync daemon (separate process)
BINANCE_REAL_ENABLED=false

# CryptoPanic API key — get from https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key_here
# CoinGecko API key — leave empty for free tier (no key needed)
COINGECKO_API_KEY=

# Database connection URL — SQLite for dev, PostgreSQL for prod
DATABASE_URL=sqlite:///./alphacore.db
# Logging level — DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Initial portfolio capital in USDT
PORTFOLIO_INITIAL_CAPITAL=10000
# Maximum position size as a fraction of total capital (0.05 = 5%)
MAX_POSITION_SIZE_PCT=0.05
# Stop-loss threshold as a fraction of position value (0.03 = 3%)
STOP_LOSS_PCT=0.03
# Trading fee as a fraction of trade value (0.001 = 0.1%, Binance standard)
TRADING_FEE_PCT=0.001
# Maximum position size in USD — absolute dollar cap applied alongside the percentage cap
MAX_POSITION_SIZE_USD=500
# Pause all new entry trades (True/False). Can also be toggled via API.
TRADING_PAUSED=False

# Comma-separated list of trading pairs
TRADING_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT,ADA/USDT

# Directory for trained model checkpoint files
MODEL_CHECKPOINT_DIR=./models_saved
# Directory for cached OHLCV data files
DATA_CACHE_DIR=./data_cache

# CryptoCompare API key — leave empty if not using (deprecated, RSS used instead)
CRYPTOCOMPARE_API_KEY=

# Reddit API credentials — leave empty if not using (deprecated, RSS used instead)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=AlphaCore/1.0

# Alert webhook URL (Discord / Telegram) — leave empty to disable alerts
# Get a Discord webhook: Server Settings → Integrations → Webhooks → New Webhook
# Get a Telegram bot token + chat ID from @BotFather
ALERT_WEBHOOK_URL=
